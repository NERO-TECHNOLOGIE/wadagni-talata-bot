# ─── EXPRESS SERVER ──────────────────────────────────────────────────────────
PORT=3000

# ─── API SÉCURITÉ ────────────────────────────────────────────────────────────
# Clé secrète pour l'API REST des meetings (POST/DELETE /meetings/:id/content)
# Génère une clé forte : openssl rand -hex 32
API_KEY=change_me_with_a_strong_secret_key

# ─── NOTES ──────────────────────────────────────────────────────────────────
# Ce bot est désormais 100% AUTONOME (Zéro API externe).
# Les sessions, utilisateurs, votes et contenus de meeting sont stockés localement.
# Base de données : ./sessions/database.sqlite
